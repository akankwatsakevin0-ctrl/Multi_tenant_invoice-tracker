# =============================================================================
# Database Configuration - Global Multi-Tenant Invoice Tracker
# =============================================================================
# Copy this file to .env and update the values for your environment.
#   cp .env.example .env
# =============================================================================

# --- Database Connection ----------------------------------------------------
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# Examples:
DATABASE_URL="postgresql://invoice_user:your_secure_password@localhost:5432/invoice_tracker"
# DATABASE_URL="postgresql://invoice_user:your_secure_password@db-host.company.com:5432/invoice_tracker?sslmode=require"

# --- SSL Configuration ------------------------------------------------------
# Set to 'true' if your database requires SSL connections (e.g., cloud-hosted).
DB_SSL=false

# --- Connection Pool Settings -----------------------------------------------
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Migration Settings -----------------------------------------------------
# The schema where migration tracking table will be created
DB_SCHEMA=public

# --- Environment ------------------------------------------------------------
NODE_ENV=development

# --- JWT Configuration ------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=change-me-in-production-use-a-strong-random-secret
JWT_EXPIRES_IN=24h

# --- Server Port ------------------------------------------------------------
PORT=3001

# --- Deployment Settings ----------------------------------------------------
# In production, set allowed public origins.
# Use a comma-separated list for multiple origins.
CORS_ORIGIN=https://your-app.example.com
TRUST_PROXY=true
RATE_LIMIT_MAX=100

# --- Deployment Settings ----------------------------------------------------
# In production, set this to the public origin(s) allowed to access the API.
# Use a comma-separated list for multiple origins.
CORS_ORIGIN=https://your-app.example.com

# Trust X-Forwarded-* headers when running behind a proxy or load balancer.
TRUST_PROXY=true

# Request rate limiting.
RATE_LIMIT_MAX=100
