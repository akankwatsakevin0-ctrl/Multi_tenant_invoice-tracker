{
    "name": "multi-tenant-invoice-tracker-server",
    "version": "1.0.0",
    "description": "Backend server for the Global Multi-Tenant Invoice Tracker",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "ts-node src/index.ts",
        "dev:watch": "nodemon --exec ts-node src/index.ts",
        "migrate": "node db/migrate.js up",
        "migrate:down": "node db/migrate.js down",
        "migrate:status": "node db/migrate.js status",
        "migrate:create": "node db/migrate.js create",
        "seed": "node db/seed.js",
        "db:setup": "npm run migrate && npm run seed",
        "lint": "tsc --noEmit",
        "lint:eslint": "eslint src/",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.0",
        "express-rate-limit": "^7.1.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.12.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^20.14.0",
        "@types/pg": "^8.11.6",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "nodemon": "^3.1.0",
        "prettier": "^3.9.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.5.0",
        "typescript-eslint": "^8.63.0",
        "vitest": "^4.1.10"
    }
}
